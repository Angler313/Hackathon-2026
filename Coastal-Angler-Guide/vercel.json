{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/api-server --filter @workspace/fishing-app run build",
  "outputDirectory": "artifacts/fishing-app/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
